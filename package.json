{
  "name": "agent-permissions-editor",
  "version": "0.3.0",
  "private": true,
  "description": "Local-first desktop editor for AI coding agent permission files.",
  "type": "module",
  "scripts": {
    "dev": "npm run dev -w @agent-permissions-editor/desktop",
    "tauri": "node scripts/tauri.mjs",
    "build": "npm run build --workspaces",
    "test": "npm run test -w @agent-permissions-editor/core",
    "typecheck": "npm run typecheck --workspaces"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  }
}
